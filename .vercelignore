# Vercel Configuration

# Build command for monorepo
# Vercel will use turbo.json to orchestrate builds

# Node version
NODE_VERSION=22

# Install command
# npm install (runs at root)

# Environment variables (set these in Vercel dashboard)
# DATABASE_URL
# JWT_SECRET  
# QR_SECRET
# FRONTEND_URL
# NEXT_PUBLIC_API_URL
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID
